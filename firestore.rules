rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // DEFAULT DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          getUserData().role == 'admin' || 
          (request.auth.token.email == "mfmf98236@gmail.com" && request.auth.token.email_verified == true)
        )
      );
    }

    function isTutor() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        getUserData().role == 'tutor' || isAdmin()
      );
    }

    function hasActiveSubscription() {
      return isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().subscriptionStatus == 'active');
    }

    // ===============================================================
    // VALIDATION HELPERS
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['user', 'tutor', 'admin'];
    }

    // ===============================================================
    // COLLECTIONS
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.role != 'admin'; 
      
      allow update: if isOwner(userId) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'lastLogin', 'mfaEnabled', 'biometricVerified', 'subscriptionStatus'])
      ) || isAdmin();
    }

    match /courses/{courseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isAdmin();
      allow update: if isAdmin() || (isTutor() && resource.data.tutorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /materials/{materialId} {
      allow get: if isSignedIn() && (
        !resource.data.isPremium || hasActiveSubscription()
      );
      
      allow list: if isSignedIn();

      allow create: if isTutor() || isAdmin();
      allow update: if isAdmin() || (isTutor() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /activityLogs/{logId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }
  }
}
